# Supabase — client (browser-safe) keys
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Maps — Places Autocomplete for business address (enable Places API)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Server-only key — DO NOT expose in the client bundle.
# Used only by serverless/edge functions (e.g. admin user creation).
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email (Resend — free tier: 3,000 emails/month)
# Sign up at https://resend.com → API Keys → create key
# Set as Supabase secret (NOT in .env — server-only):
#   supabase secrets set RESEND_API_KEY=re_xxxxxxxx
#   supabase secrets set FORM101_EMAIL_FROM="אביחי <onboarding@resend.dev>"
# For production, verify your domain in Resend and use e.g. noreply@yourdomain.com
